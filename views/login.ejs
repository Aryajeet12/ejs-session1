<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
</head>
<body>
<h1>Login form</h1>
<form action="/login" method="POST">
    <p>
        <input type="text" name="email" placeholder="Email">
    </p>
    <p>
        <input type="password" name="password" placeholder="Password">
    </p>
    <p>
        <button type="submit">Login</button>
    </p>
</form>
</body>
</html>